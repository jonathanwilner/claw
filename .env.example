OPENCLAW_IMAGE=openclaw/openclaw:latest
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_MODEL=glm-4.7-flash
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=0.0.0.0
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
OPENCLAW_TZ=America/Los_Angeles
OLLAMA_API_KEY=local-ollama
OPENCLAW_CONFIG_DIR=./state/openclaw-config
OPENCLAW_WORKSPACE_DIR=./state/openclaw-workspace
OLLAMA_DATA_DIR=./state/ollama
PLAYWRIGHT_BROWSERS_PATH=/home/node/.cache/ms-playwright
